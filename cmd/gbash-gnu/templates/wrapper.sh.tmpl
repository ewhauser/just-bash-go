#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
root_dir=$(CDPATH= cd -- "$script_dir/.." && pwd -P)
host_pwd=${PWD-}
if [ -n "$host_pwd" ]; then
  case "$host_pwd" in
    "$root_dir"|"$root_dir"/*) : ;;
    *) host_pwd= ;;
  esac
fi
if [ -z "$host_pwd" ]; then
  host_pwd=$(pwd -P)
fi
sandbox_cwd=/
case "$host_pwd" in
  "$root_dir") ;;
  "$root_dir"/*) sandbox_cwd="/${host_pwd#"$root_dir"/}" ;;
esac
gbash_bin=$root_dir/build-aux/gbash-harness/gbash
{{if .CommandNameQuoted}}exec "$gbash_bin" --readwrite-root "$root_dir" --cwd "$sandbox_cwd" -c 'exec "$@"' _ {{.CommandNameQuoted}} "$@"
{{else}}exec "$gbash_bin" --readwrite-root "$root_dir" --cwd "$sandbox_cwd" "$@"
{{end}}
