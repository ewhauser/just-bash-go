{
  "gnu_version": "9.10",
  "tarball_url": "https://ftp.gnu.org/gnu/coreutils/coreutils-9.10.tar.gz",
  "tarball_sha256": "e0bde1fb68509447fc723cf2517e8a8c7fa46769919bb7490ed350a2e9238562",
  "utility_display_names": [
    { "name": "install", "alias": "ginstall" }
  ],
  "utility_overrides": [
    { "name": "[", "patterns": ["tests/test/*", "tests/misc/invalid-opt.pl"] },
    { "name": "arch", "patterns": ["tests/misc/arch.sh"] },
    { "name": "b2sum", "patterns": ["tests/cksum/b2sum.sh"] },
    { "name": "base32", "patterns": ["tests/basenc/bounded-memory.sh", "tests/basenc/large-input.sh"] },
    { "name": "base64", "patterns": ["tests/basenc/base64.pl", "tests/basenc/bounded-memory.sh", "tests/basenc/large-input.sh"] },
    { "name": "basename", "patterns": ["tests/misc/basename*"] },
    { "name": "basenc", "patterns": ["tests/basenc/basenc.pl", "tests/basenc/bounded-memory.sh", "tests/basenc/large-input.sh"] },
    { "name": "cksum", "patterns": ["tests/cksum/cksum*"] },
    { "name": "comm", "patterns": ["tests/misc/comm*"] },
    { "name": "coreutils", "patterns": ["tests/misc/coreutils.sh"] },
    { "name": "dir", "patterns": ["tests/ls/*", "tests/misc/invalid-opt.pl"] },
    { "name": "dircolors", "patterns": ["tests/misc/dircolors.pl"] },
    { "name": "dirname", "patterns": ["tests/misc/dirname*"] },
    { "name": "echo", "patterns": ["tests/misc/echo*"] },
    { "name": "false", "patterns": ["tests/misc/false-status.sh"] },
    { "name": "ginstall", "patterns": ["tests/install/*"] },
    { "name": "kill", "patterns": ["tests/misc/kill.sh"] },
    { "name": "link", "patterns": ["tests/misc/invalid-opt.pl"] },
    { "name": "md5sum", "patterns": ["tests/cksum/md5sum*"] },
    { "name": "mkfifo", "patterns": ["tests/misc/mknod.sh"] },
    { "name": "mknod", "patterns": ["tests/misc/mknod.sh"] },
    { "name": "nl", "patterns": ["tests/misc/nl*"] },
    { "name": "nohup", "patterns": ["tests/misc/nohup.sh"] },
    { "name": "pathchk", "patterns": ["tests/misc/pathchk.sh"] },
    { "name": "printenv", "patterns": ["tests/misc/printenv.sh"] },
    { "name": "realpath", "patterns": ["tests/misc/realpath.sh"] },
    { "name": "sha1sum", "patterns": ["tests/cksum/sha1sum*"] },
    { "name": "sha224sum", "patterns": ["tests/cksum/sha224sum*"] },
    { "name": "sha256sum", "patterns": ["tests/cksum/sha256sum*"] },
    { "name": "sha384sum", "patterns": ["tests/cksum/sha384sum*"] },
    { "name": "sha512sum", "patterns": ["tests/cksum/sha512sum*"] },
    { "name": "sleep", "patterns": ["tests/misc/sleep*"] },
    { "name": "stdbuf", "patterns": ["tests/misc/stdbuf.sh"] },
    { "name": "sum", "patterns": ["tests/cksum/sum*"] },
    { "name": "sync", "patterns": ["tests/misc/sync.sh"] },
    { "name": "tsort", "patterns": ["tests/misc/tsort.pl"] },
    { "name": "vdir", "patterns": ["tests/ls/*"] },
    { "name": "whoami", "patterns": ["tests/chroot/chroot-credentials.sh"] },
    { "name": "yes", "patterns": ["tests/misc/yes.sh"] }
  ],
  "attribution_rules": [
    { "patterns": ["tests/test/*"], "commands": ["test"], "kind": "direct" },
    { "patterns": ["tests/test/*"], "commands": ["["], "kind": "alias" },
    { "patterns": ["tests/ls/*"], "commands": ["dir", "vdir"], "kind": "alias" },
    { "patterns": ["tests/misc/mknod.sh"], "commands": ["mkfifo"], "kind": "shared" },
    { "patterns": ["tests/chroot/chroot-credentials.sh"], "commands": ["whoami"], "kind": "shared" },
    { "patterns": ["tests/basenc/base64.pl"], "commands": ["base64"], "kind": "direct" },
    { "patterns": ["tests/basenc/basenc.pl"], "commands": ["basenc"], "kind": "direct" },
    { "patterns": ["tests/basenc/bounded-memory.sh", "tests/basenc/large-input.sh"], "commands": ["base32", "base64"], "kind": "shared" },
    { "patterns": ["tests/cksum/b2sum.sh"], "commands": ["b2sum"], "kind": "direct" },
    { "patterns": ["tests/cksum/md5sum*"], "commands": ["md5sum"], "kind": "direct" },
    { "patterns": ["tests/cksum/sha1sum*"], "commands": ["sha1sum"], "kind": "direct" },
    { "patterns": ["tests/cksum/sha224sum*"], "commands": ["sha224sum"], "kind": "direct" },
    { "patterns": ["tests/cksum/sha256sum*"], "commands": ["sha256sum"], "kind": "direct" },
    { "patterns": ["tests/cksum/sha384sum*"], "commands": ["sha384sum"], "kind": "direct" },
    { "patterns": ["tests/cksum/sha512sum*"], "commands": ["sha512sum"], "kind": "direct" },
    { "patterns": ["tests/cksum/sum*"], "commands": ["sum"], "kind": "direct" },
    { "patterns": ["tests/misc/false-status.sh"], "commands": ["false"], "kind": "direct" }
  ],
  "skip_patterns": [
    { "pattern": "tests/chcon/*", "reason": "SELinux command tests are out of scope in v1" },
    { "pattern": "tests/help/*", "reason": "help/version tests are skipped in v1" },
    { "pattern": "tests/runcon/*", "reason": "SELinux command tests are out of scope in v1" },
    { "pattern": "tests/*/selinux*", "reason": "SELinux tests are out of scope in v1" }
  ]
}
